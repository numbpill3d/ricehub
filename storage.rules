rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Post attachments - public read, owner write
    match /posts/{postId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null &&
        // Verify the user owns the post via Firestore
        exists(/databases/(default)/documents/posts/{postId}) &&
        get(/databases/(default)/documents/posts/{postId}).data.handle == request.auth.uid &&
        request.resource.size < 10 * 1024 * 1024 && // 10MB limit
        request.resource.contentType.matches('image/.*|text/.*|application/json|application/octet-stream');
    }

    // User avatars
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId &&
        request.resource.size < 2 * 1024 * 1024 && // 2MB limit
        request.resource.contentType.matches('image/.*');
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}